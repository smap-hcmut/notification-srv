apiVersion: v1
kind: Secret
metadata:
  name: notification-secrets
  namespace: smap
  labels:
    app: notification-api
type: Opaque
stringData:
  # Redis Configuration
  REDIS_PASSWORD: "CHANGE_ME"

  # JWT Configuration
  JWT_SECRET_KEY: "CHANGE_ME_min_32_chars"

  # Discord Webhook (Optional)
  DISCORD_WEBHOOK_URL: ""
